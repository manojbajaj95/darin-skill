{
  "order": ["landing", "pricing", "onboarding", "docs", "seo"],
  "max_files": 8,
  "skip_dirs": [
    "node_modules",
    ".git",
    "dist",
    "build",
    ".next",
    "coverage",
    ".turbo",
    "vendor"
  ],
  "landing": {
    "keywords": [
      "landing",
      "landing page",
      "homepage",
      "home page",
      "marketing",
      "marketing site",
      "hero"
    ],
    "globs": ["**/page.tsx", "**/page.jsx", "**/index.html", "**/Landing*.tsx", "**/Landing*.jsx"],
    "path_hints": ["landing", "marketing", "home", "(marketing)"]
  },
  "pricing": {
    "keywords": ["pricing", "plans", "plans page", "billing", "tiers", "subscription"],
    "globs": ["**/page.tsx", "**/page.jsx", "**/*ricing*.tsx", "**/*ricing*.jsx", "**/*lan*.tsx"],
    "path_hints": ["pricing", "plans", "billing", "subscribe", "subscription"]
  },
  "onboarding": {
    "keywords": [
      "onboarding",
      "signup",
      "sign up",
      "sign-up",
      "first run",
      "first-run",
      "activation",
      "welcome",
      "getting started flow"
    ],
    "globs": ["**/page.tsx", "**/page.jsx", "**/*nboard*.tsx", "**/*ignup*.tsx", "**/*elcome*.tsx"],
    "path_hints": ["onboarding", "signup", "sign-up", "welcome", "activate", "activation", "first-run"]
  },
  "docs": {
    "keywords": ["docs", "documentation", "getting started", "readme", "guide"],
    "globs": ["**/README.md", "**/*.mdx", "**/docs/**/*.md", "**/docs/**/*.mdx"],
    "path_hints": ["docs", "documentation", "guide", "getting-started", "getting_started"]
  },
  "seo": {
    "keywords": ["seo", "meta", "meta tags", "page titles", "title tag", "open graph", "sitemap"],
    "globs": [
      "**/layout.tsx",
      "**/layout.jsx",
      "**/_document.tsx",
      "**/sitemap.ts",
      "**/sitemap.xml",
      "**/robots.ts",
      "**/robots.txt"
    ],
    "path_hints": ["layout", "metadata", "head", "sitemap", "robots", "seo"]
  }
}
